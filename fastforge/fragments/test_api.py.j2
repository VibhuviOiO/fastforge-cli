from httpx import AsyncClient


class Test{{ Name }}API:
    async def test_create_{{ name }}(self, client: AsyncClient):
        payload = {"name": "Test {{ Name }}", "description": "A test"}
        response = await client.post("/api/v1/{{ names }}/", json=payload)
        assert response.status_code == 201
        data = response.json()
        assert data["name"] == "Test {{ Name }}"
        assert "id" in data

    async def test_list_{{ names }}(self, client: AsyncClient):
        response = await client.get("/api/v1/{{ names }}/")
        assert response.status_code == 200
        body = response.json()
        assert "{{ names }}" in body
        assert body["limit"] == 50
        assert body["offset"] == 0

    async def test_get_{{ name }}_not_found(self, client: AsyncClient):
        response = await client.get("/api/v1/{{ names }}/nonexistent")
        assert response.status_code == 404

    async def test_create_{{ name }}_validation_error(self, client: AsyncClient):
        response = await client.post("/api/v1/{{ names }}/", json={})
        assert response.status_code == 422
