"""Service layer for {{ Name }} — Business logic (SOLID: Single Responsibility)."""

from app.api.models.{{ name }} import (
    {{ Name }}Create,
    {{ Name }}ListResponse,
    {{ Name }}Response,
    {{ Name }}Update,
)
{%- if logging == "structlog" %}
from app.logging_config import get_logger
{%- else %}
from logging import getLogger
{%- endif %}
from app.repositories.{{ name }}_repository import {{ Name }}Repository

{% if logging == "structlog" -%}
logger = get_logger(__name__)
{%- else -%}
logger = getLogger(__name__)
{%- endif %}


class {{ Name }}Service:
    """Encapsulates business logic — depends on repository interface, not implementation (SOLID: DIP)."""

    def __init__(self, repository: {{ Name }}Repository) -> None:
        self._repo = repository

    async def create(self, data: {{ Name }}Create) -> {{ Name }}Response:
        result = await self._repo.create(data)
{%- if logging == "structlog" %}
        await logger.ainfo("{{ name }}_created", id=result.id, name=data.name)
{%- else %}
        logger.info("{{ name }}_created: %s", result.id)
{%- endif %}
        return result

    async def get_by_id(self, item_id: str) -> {{ Name }}Response | None:
        return await self._repo.get_by_id(item_id)

    async def list_all(self) -> {{ Name }}ListResponse:
        items = await self._repo.list_all()
        return {{ Name }}ListResponse({{ names }}=items, total=len(items))

    async def update(self, item_id: str, data: {{ Name }}Update) -> {{ Name }}Response | None:
        result = await self._repo.update(item_id, data)
{%- if logging == "structlog" %}
        if result:
            await logger.ainfo("{{ name }}_updated", id=item_id)
{%- else %}
        if result:
            logger.info("{{ name }}_updated: %s", item_id)
{%- endif %}
        return result

    async def delete(self, item_id: str) -> bool:
        deleted = await self._repo.delete(item_id)
{%- if logging == "structlog" %}
        if deleted:
            await logger.ainfo("{{ name }}_deleted", id=item_id)
{%- else %}
        if deleted:
            logger.info("{{ name }}_deleted: %s", item_id)
{%- endif %}
        return deleted
