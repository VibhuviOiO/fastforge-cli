# {{ cookiecutter.project_name }} — Local Development
#
# Copy this file to `.env` and adjust values for your local environment.
# All values below are safe defaults for running the app locally with
# `docker compose -f infra/docker-compose.yml up`.

# ── App ──────────────────────────────────────────────────────────────────
APP_NAME={{ cookiecutter.project_slug }}
APP_ENV=local
APP_DEBUG=true
APP_PORT={{ cookiecutter.port }}
APP_LOG_LEVEL=debug

# ── Logging ──────────────────────────────────────────────────────────────
LOG_FORMAT={{ cookiecutter.log_format }}

{%- if cookiecutter.database == "postgres" %}

# ── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB={{ cookiecutter.package_name }}
POSTGRES_USER={{ cookiecutter.package_name }}
POSTGRES_PASSWORD=change-me-locally
DATABASE_URL=postgresql+asyncpg://{{ cookiecutter.package_name }}:change-me-locally@postgres:5432/{{ cookiecutter.package_name }}
{%- elif cookiecutter.database == "mongodb" %}

# ── MongoDB ──────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB={{ cookiecutter.package_name }}
{%- endif %}
{%- if cookiecutter.cache == "redis" %}

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
{%- endif %}
{%- if cookiecutter.streaming == "kafka" %}

# ── Kafka ────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PREFIX={{ cookiecutter.package_name }}
{%- endif %}
{%- if cookiecutter.secrets == "vault" %}

# ── Vault ────────────────────────────────────────────────────────────────
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=dev-only-root-token
{%- endif %}

# ── Notes ────────────────────────────────────────────────────────────────
# - For staging/production values see .env.staging and .env.production
# - Never commit a real .env file — it is gitignored
